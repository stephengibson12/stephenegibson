# SEG outreach environment variables.
# Copy to .env and fill in. .env is gitignored.

# Outreach sender identity.
SEG_SENDER_EMAIL=hello@stephenegibson.com
SEG_SENDER_NAME=Stephen Gibson

# SendGrid (send side). One key per SendGrid account; we use the
# same SendGrid account as MZ/GL with stephenegibson.com authenticated
# as a sender domain.
SENDGRID_API_KEY=

# OpenAI (AI content generation for outreach drafts).
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-5-nano
OPENAI_MODEL_QUALITY=gpt-5

# Gmail OAuth (read side). Paths to credential files; both live OUTSIDE
# the repo for security. The client JSON is downloaded from Google Cloud
# Console (Desktop app OAuth client); the token JSON is created by
# scripts/seg_oauth_bootstrap.py on first run.
SEG_OAUTH_CLIENT_JSON=~/.config/seg-outreach/oauth_client.json
SEG_GMAIL_TOKEN_JSON=~/.config/seg-outreach/gmail_token.json

# Firestore project (uses Application Default Credentials —
# run `gcloud auth application-default login` once).
FIRESTORE_PROJECT=stephenegibson
